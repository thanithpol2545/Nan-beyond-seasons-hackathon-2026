import React, { useState } from "react";
import { ShoppingBag, Filter, Trash2, Plus, Minus, X, Check, Heart, ShieldCheck } from "lucide-react";
import { EcomProduct, CartItem } from "../types";
import { PRODUCTS_DATA } from "../data/nanDataset";

interface Props {
  cart: CartItem[];
  onUpdateCartQuantity: (productId: string, quantity: number) => void;
  onRemoveFromCart: (productId: string) => void;
  onClearCart: () => void;
  onAddProductToCart: (productId: string) => void;
}

export default function EcomBoutique({
  cart,
  onUpdateCartQuantity,
  onRemoveFromCart,
  onClearCart,
  onAddProductToCart
}: Props) {
  const [activeCategory, setActiveFilter] = useState<string>("all");
  const [isCartOpen, setIsCartOpen] = useState(false);
  const [checkoutStep, setCheckoutStep] = useState<"idle" | "form" | "success">("idle");
  
  // Shipping Form State
  const [shippingName, setShippingName] = useState("");
  const [shippingAddress, setShippingAddress] = useState("");
  const [shippingPhone, setShippingPhone] = useState("");

  const filteredProducts = activeCategory === "all"
    ? PRODUCTS_DATA
    : PRODUCTS_DATA.filter((p) => p.category === activeCategory);

  const cartSubtotal = cart.reduce((sum, item) => sum + item.product.price * item.quantity, 0);
  const totalQuantity = cart.reduce((sum, item) => sum + item.quantity, 0);

  const handleCheckoutSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (!shippingName || !shippingAddress || !shippingPhone) return;
    setCheckoutStep("success");
  };

  const handleFinishCheckout = () => {
    onClearCart();
    setCheckoutStep("idle");
    setIsCartOpen(false);
    setShippingName("");
    setShippingAddress("");
    setShippingPhone("");
  };

  return (
    <div className="space-y-8">
      {/* Category filters */}
      <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 border-b border-[#2a2e28] pb-6">
        <div className="flex flex-wrap gap-2">
          {[
            { id: "all", label: "พรรณพฤกษาทั้งหมด" },
            { id: "tea", label: "ชาเกสร & ดอกไม้" },
            { id: "oil", label: "น้ำมันหอมนวดตัว" },
            { id: "body", label: "สครับดีท็อกซ์ผิว" },
            { id: "pass", label: "บัตรกำนัลบำบัด" }
          ].map((cat) => (
            <button
              key={cat.id}
              onClick={() => setActiveFilter(cat.id)}
              className={`py-2 px-4 rounded-full text-xs font-display font-medium transition-all ${
                activeCategory === cat.id
                  ? "bg-[#c9b097] text-[#0d0f0c] font-bold"
                  : "bg-[#161a15] text-[#819177] hover:text-[#f2f4f1] border border-[#2a2e28]"
              }`}
            >
              {cat.label}
            </button>
          ))}
        </div>

        {/* Floating Cart Indicator */}
        <button
          onClick={() => setIsCartOpen(true)}
          className="flex items-center gap-2 bg-[#161a15] hover:bg-[#2a2e28] border border-[#2a2e28] px-5 py-2.5 rounded-full text-xs text-[#f2f4f1] transition-all font-display"
        >
          <ShoppingBag className="h-4 w-4 text-[#c9b097]" />
          <span>รถเข็นบำบัดของคุณ ({totalQuantity})</span>
        </button>
      </div>

      {/* Boutique Product Grid */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {filteredProducts.map((p) => (
          <div
            key={p.id}
            className="group bg-[#161a15] rounded-3xl border border-[#2a2e28] overflow-hidden hover:border-[#c9b097]/40 transition-all flex flex-col justify-between"
          >
            {/* Image container */}
            <div className="relative aspect-square overflow-hidden bg-black border-b border-[#2a2e28]">
              <img
                src={p.image_url}
                alt={p.name}
                className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
              <span className="absolute top-4 left-4 bg-black/60 backdrop-blur-md text-[9px] font-mono text-[#c9b097] uppercase px-3 py-1 rounded-full border border-white/10">
                {p.scent_family || "Organic"}
              </span>
            </div>

            {/* Description Body */}
            <div className="p-5 flex-1 flex flex-col justify-between">
              <div>
                <span className="text-[10px] font-mono text-[#819177] uppercase block">{p.source.split(" จังหวัด")[0]}</span>
                <h4 className="font-display font-semibold text-[#f2f4f1] text-xs mt-1 leading-relaxed">
                  {p.name}
                </h4>
                
                {/* Ingredients tag list */}
                <div className="flex flex-wrap gap-1 mt-3">
                  {p.ingredients.slice(0, 3).map((ing, idx) => (
                    <span
                      key={idx}
                      className="text-[9px] px-2 py-0.5 rounded-md bg-[#0d0f0c] text-[#819177] border border-[#2a2e28]"
                    >
                      {ing}
                    </span>
                  ))}
                  {p.ingredients.length > 3 && (
                    <span className="text-[9px] text-[#819177] self-center ml-1">+{p.ingredients.length - 3}</span>
                  )}
                </div>

                <p className="text-[11px] text-[#819177] mt-3 leading-relaxed">
                  {p.benefits[0]}
                </p>
              </div>

              <div className="mt-5 pt-4 border-t border-[#2a2e28]/50 flex items-center justify-between gap-4">
                <span className="font-mono text-sm font-bold text-[#c9b097] shrink-0">
                  {p.price.toLocaleString()} ฿
                </span>
                <button
                  onClick={() => onAddProductToCart(p.id)}
                  className="flex-1 py-2.5 rounded-full bg-[#c9b097] text-[#0d0f0c] hover:bg-[#b09a82] active:scale-95 text-center font-display font-semibold text-[10px] uppercase tracking-wider transition-all"
                >
                  ใส่ในรถเข็น
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Slide-over Side Cart Drawer & Checkout Forms */}
      {isCartOpen && (
        <div className="fixed inset-0 z-50 bg-black/60 backdrop-blur-xs flex justify-end animate-fade-in">
          <div className="h-full w-full max-w-lg bg-[#0d0f0c] border-l border-[#2a2e28] p-6 shadow-2xl flex flex-col justify-between overflow-y-auto">
            {/* Cart Header */}
            <div className="flex items-center justify-between pb-4 border-b border-[#2a2e28]">
              <div className="flex items-center gap-2">
                <ShoppingBag className="h-5 w-5 text-[#c9b097]" />
                <h4 className="font-display font-semibold text-[#f2f4f1] text-sm uppercase tracking-wider">
                  ตะกร้าของใช้สมุนไพรน่าน
                </h4>
              </div>
              <button
                onClick={() => setIsCartOpen(false)}
                className="p-1 rounded-md hover:bg-[#161a15] text-[#819177] hover:text-[#f2f4f1] transition-colors"
              >
                <X className="h-4 w-4" />
              </button>
            </div>

            {/* Steps Rendering */}
            {checkoutStep === "idle" && (
              <>
                {/* List items */}
                <div className="flex-1 overflow-y-auto py-4 space-y-4 scrollbar-thin">
                  {cart.length === 0 ? (
                    <div className="text-center py-20 text-[#819177] space-y-3">
                      <ShoppingBag className="h-10 w-10 text-[#2a2e28] mx-auto" />
                      <p className="text-xs">ยังไม่มีเครื่องพฤกษาบำบัดในรถเข็นของคุณเจ้า</p>
                    </div>
                  ) : (
                    cart.map((item) => (
                      <div
                        key={item.product.id}
                        className="flex items-center gap-4 bg-[#161a15] p-3 rounded-2xl border border-[#2a2e28]"
                      >
                        <img
                          src={item.product.image_url}
                          alt={item.product.name}
                          className="h-14 w-14 rounded-xl object-cover border border-[#2a2e28]"
                        />
                        <div className="flex-1 min-w-0">
                          <h5 className="font-display font-semibold text-[#f2f4f1] text-[11px] truncate leading-tight">
                            {item.product.name}
                          </h5>
                          <span className="text-[10px] font-mono text-[#c9b097] mt-0.5 block">
                            {(item.product.price * item.quantity).toLocaleString()} ฿
                          </span>
                          <div className="flex items-center gap-2 mt-1">
                            <button
                              onClick={() => onUpdateCartQuantity(item.product.id, item.quantity - 1)}
                              className="p-1 rounded-md bg-[#0d0f0c] border border-[#2a2e28] text-[#819177] hover:text-[#f2f4f1]"
                            >
                              <Minus className="h-3 w-3" />
                            </button>
                            <span className="text-[10px] text-white font-mono min-w-[12px] text-center">
                              {item.quantity}
                            </span>
                            <button
                              onClick={() => onUpdateCartQuantity(item.product.id, item.quantity + 1)}
                              className="p-1 rounded-md bg-[#0d0f0c] border border-[#2a2e28] text-[#819177] hover:text-[#f2f4f1]"
                            >
                              <Plus className="h-3 w-3" />
                            </button>
                          </div>
                        </div>
                        <button
                          onClick={() => onRemoveFromCart(item.product.id)}
                          className="p-2 text-[#819177] hover:text-red-400 rounded-md hover:bg-[#0d0f0c] transition-colors"
                        >
                          <Trash2 className="h-3.5 w-3.5" />
                        </button>
                      </div>
                    ))
                  )}
                </div>

                {/* Totals & Proceed */}
                {cart.length > 0 && (
                  <div className="pt-4 border-t border-[#2a2e28] space-y-4 bg-[#0d0f0c]">
                    <div className="flex justify-between items-center text-xs">
                      <span className="text-[#819177]">ยอดรวมพฤกษาบำบัด:</span>
                      <span className="font-mono text-sm font-bold text-[#c9b097]">
                        {cartSubtotal.toLocaleString()} ฿
                      </span>
                    </div>

                    <button
                      onClick={() => setCheckoutStep("form")}
                      className="w-full py-3 rounded-full bg-[#c9b097] text-[#0d0f0c] font-display font-semibold text-xs tracking-wider uppercase text-center hover:bg-[#b09a82] transition-colors"
                    >
                      กรอกที่จัดส่งเพื่อเช็คเอาท์
                    </button>
                  </div>
                )}
              </>
            )}

            {checkoutStep === "form" && (
              <form onSubmit={handleCheckoutSubmit} className="flex-1 flex flex-col justify-between py-4">
                <div className="space-y-4">
                  <span className="text-[10px] font-mono text-[#c9b097] uppercase tracking-wider block">
                    STEP 2 // SHIPPING INFORMATION
                  </span>

                  <div>
                    <label className="block text-[11px] font-display font-semibold uppercase tracking-wider text-[#819177] mb-1.5">
                      ชื่อผู้รับเครื่องหอม (Full Name)
                    </label>
                    <input
                      type="text"
                      required
                      value={shippingName}
                      onChange={(e) => setShippingName(e.target.value)}
                      placeholder="เช่น สมชาย สุวรรณเวช"
                      className="w-full bg-[#161a15] border border-[#2a2e28] rounded-xl px-4 py-2.5 text-xs text-[#f2f4f1] focus:outline-hidden focus:border-[#c9b097]"
                    />
                  </div>

                  <div>
                    <label className="block text-[11px] font-display font-semibold uppercase tracking-wider text-[#819177] mb-1.5">
                      เบอร์โทรศัพท์ (Contact Phone)
                    </label>
                    <input
                      type="tel"
                      required
                      value={shippingPhone}
                      onChange={(e) => setShippingPhone(e.target.value)}
                      placeholder="เช่น 0891234567"
                      className="w-full bg-[#161a15] border border-[#2a2e28] rounded-xl px-4 py-2.5 text-xs text-[#f2f4f1] focus:outline-hidden focus:border-[#c9b097]"
                    />
                  </div>

                  <div>
                    <label className="block text-[11px] font-display font-semibold uppercase tracking-wider text-[#819177] mb-1.5">
                      ที่อยู่จัดส่งพัสดุ (Shipping Address)
                    </label>
                    <textarea
                      required
                      value={shippingAddress}
                      onChange={(e) => setShippingAddress(e.target.value)}
                      placeholder="เลขที่, ถนน, แขวง, เขต, จังหวัด, รหัสไปรษณีย์..."
                      rows={3}
                      className="w-full bg-[#161a15] border border-[#2a2e28] rounded-xl px-4 py-2.5 text-xs text-[#f2f4f1] focus:outline-hidden focus:border-[#c9b097] resize-none"
                    />
                  </div>

                  {/* Security seal */}
                  <div className="bg-[#161a15] rounded-xl p-4 border border-[#2a2e28] text-[10px] text-[#819177] flex gap-2">
                    <ShieldCheck className="h-4 w-4 text-[#c9b097] shrink-0" />
                    <span>ชำระเงินระบบล้านนาการันตี ปลอดภัย อุดหนุนเกษตรกรน่านแท้ 100%</span>
                  </div>
                </div>

                <div className="pt-4 border-t border-[#2a2e28] flex gap-2">
                  <button
                    type="button"
                    onClick={() => setCheckoutStep("idle")}
                    className="flex-1 py-3 rounded-full border border-[#2a2e28] text-[#819177] hover:text-[#f2f4f1] font-display text-xs text-center uppercase tracking-wider"
                  >
                    กลับไปดูสินค้า
                  </button>
                  <button
                    type="submit"
                    className="flex-1 py-3 rounded-full bg-[#c9b097] text-[#0d0f0c] hover:bg-[#b09a82] font-display font-bold text-xs text-center uppercase tracking-wider"
                  >
                    ยืนยันคำสั่งซื้อ
                  </button>
                </div>
              </form>
            )}

            {checkoutStep === "success" && (
              <div className="flex-1 flex flex-col justify-between py-6 text-center animate-fade-in">
                <div className="space-y-6">
                  <div className="h-14 w-14 rounded-full bg-emerald-950 border border-emerald-400 flex items-center justify-center mx-auto text-emerald-400">
                    <Check className="h-6 w-6" />
                  </div>
                  <div className="space-y-2">
                    <span className="text-[10px] font-mono text-[#c9b097] uppercase tracking-widest block">ORDER SUCCESSFUL</span>
                    <h5 className="font-serif italic text-2xl text-[#f2f4f1]">บันทึกใบสั่งซื้อเสร็จสิ้น</h5>
                    <p className="text-xs text-[#819177] max-w-sm mx-auto leading-relaxed">
                      พวงมาลัยและวิสาหกิจชุมชนบ่อสวกน่าน ได้รับคำสั่งสั่งซื้อเรียบร้อยแล้วเจ้า... พัสดุของใช้สมุนไพรกลิ่นอายธรรมชาติจะออกเดินทางสู่กุฏิและบ้านท่านในเร็ววันเจ้า
                    </p>
                  </div>

                  {/* Printable Invoice Block */}
                  <div className="bg-[#161a15] rounded-2xl p-5 border border-[#2a2e28] text-left space-y-3 font-mono text-[11px] text-[#819177]">
                    <div className="flex justify-between border-b border-[#2a2e28]/50 pb-2">
                      <span>ใบสั่งซื้อรหัส (ORDER_ID)</span>
                      <span className="text-white">NAN-{Date.now().toString().slice(-6)}</span>
                    </div>
                    <div className="space-y-1">
                      {cart.map((item) => (
                        <div key={item.product.id} className="flex justify-between text-white">
                          <span>{item.product.name} (x{item.quantity})</span>
                          <span>{(item.product.price * item.quantity).toLocaleString()} ฿</span>
                        </div>
                      ))}
                    </div>
                    <div className="border-t border-[#2a2e28]/50 pt-2 flex justify-between text-white font-bold text-xs">
                      <span>ยอดชำระทั้งสิ้น (GRAND TOTAL)</span>
                      <span className="text-[#c9b097]">{cartSubtotal.toLocaleString()} ฿</span>
                    </div>
                    <div className="pt-2 border-t border-[#2a2e28]/20 text-[10px] space-y-0.5">
                      <p><span className="text-white">ผู้รับ:</span> {shippingName}</p>
                      <p><span className="text-white">เบอร์โทร:</span> {shippingPhone}</p>
                      <p className="truncate"><span className="text-white">ที่อยู่จัดส่ง:</span> {shippingAddress}</p>
                    </div>
                  </div>
                </div>

                <button
                  onClick={handleFinishCheckout}
                  className="w-full py-3 rounded-full bg-[#c9b097] text-[#0d0f0c] hover:bg-[#b09a82] font-display font-semibold text-xs tracking-wider uppercase text-center"
                >
                  เสร็จสิ้นและกลับสู่ร้านค้า
                </button>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
